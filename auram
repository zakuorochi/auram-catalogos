<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AURAM - Experiencia IA</title>
    
    <script src="https://unpkg.com/@google/generative-ai@0.21.0/dist/index.js"></script>
    
    <style>
        body, html { margin: 0; padding: 0; background: #000; color: #fff; font-family: 'Helvetica', sans-serif; height: 100%; overflow: hidden; }
        #splash { display: flex; justify-content: center; align-items: center; height: 100vh; font-size: 3rem; letter-spacing: 12px; transition: 1.5s; }
        #main-app { display: none; height: 100vh; flex-direction: column; position: relative; }
        video { width: 100%; height: 100%; object-fit: cover; transform: scaleX(-1); }
        .overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: none; background: rgba(0,0,0,0.95); flex-direction: column; justify-content: center; align-items: center; padding: 25px; box-sizing: border-box; text-align: center; z-index: 10; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; width: 100%; max-width: 400px; }
        button { background: #111; color: #fff; border: 1px solid #333; padding: 15px; border-radius: 8px; cursor: pointer; font-size: 0.9rem; }
        .loader { border: 3px solid #333; border-top: 3px solid #fff; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin-bottom: 15px; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        #res-body { color: #ccc; line-height: 1.6; text-align: left; max-width: 500px; }
    </style>
</head>
<body>

    <div id="splash">AURAM</div>

    <div id="main-app">
        <video id="webcam" autoplay playsinline></video>
        <div style="position: absolute; bottom: 40px; width: 100%; text-align: center;">
            <button id="snap" style="width: 80px; height: 80px; border-radius: 50%; background: #fff; border: none; font-size: 1.5rem; color: #000;">✨</button>
        </div>

        <div id="step-occasion" class="overlay">
            <h3>¿Para qué ocasión deseas impactar?</h3>
            <div class="grid">
                <button onclick="startAI('Boda')">Boda</button>
                <button onclick="startAI('Fiesta')">Fiesta</button>
                <button onclick="startAI('Cita')">Cita</button>
                <button onclick="startAI('Casual')">Casual</button>
                <button onclick="startAI('Deporte')">Deporte</button>
                <button onclick="startAI('Trabajo')">Trabajo</button>
            </div>
        </div>

        <div id="step-loading" class="overlay">
            <div class="loader"></div>
            <p id="loading-text">Elevando tu AURA...</p>
        </div>

        <div id="step-result" class="overlay">
            <h2 id="res-title" style="color: #00d1ff;"></h2>
            <div id="res-body"></div>
            <button onclick="location.reload()" style="margin-top: 25px; background: #fff; color: #000; font-weight: bold; width: 100%; max-width: 200px;">REPETIR</button>
        </div>
    </div>

    <script>
        // --- 1. CONFIGURACIÓN ---
        const API_KEY = "AiZaSyBClcOgCE01D_95g1smORulJfm2wr9yj1M"; 
        const GITHUB_PDFS = {
            MUJER: "https://raw.githubusercontent.com/zakuorochi/auram-catalogos/main/mujer.pdf",
            HOMBRE: "https://raw.githubusercontent.com/zakuorochi/auram-catalogos/main/hombre.pdf"
        };

        let genAIModel = null;
        const video = document.getElementById('webcam');

        // --- 2. INICIALIZACIÓN DE MOTOR IA ---
        window.addEventListener('load', () => {
            console.log("Iniciando componentes...");
            setTimeout(() => {
                try {
                    const lib = window.googleGenerativeAi;
                    if (lib) {
                        const genAI = new lib.GoogleGenerativeAI(API_KEY);
                        genAIModel = genAI.getGenerativeModel({ model: "gemini-1.5-flash" });
                        console.log("✅ AURAM: Motor de IA encendido.");
                    } else {
                        console.error("❌ Error: Objeto googleGenerativeAi no encontrado.");
                    }
                } catch (e) { console.error("Error al conectar con Google:", e); }
            }, 1000);
        });

        // --- 3. UI Y CÁMARA ---
        setTimeout(() => {
            document.getElementById('splash').style.display = 'none';
            document.getElementById('main-app').style.display = 'flex';
            navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" } })
                .then(stream => video.srcObject = stream)
                .catch(err => alert("Por favor, permite el acceso a la cámara en Live Server."));
        }, 2500);

        document.getElementById('snap').onclick = () => {
            document.getElementById('step-occasion').style.display = 'flex';
        };

        async function fetchPdfBase64(url) {
            const res = await fetch(url);
            const blob = await res.blob();
            return new Promise(resolve => {
                const reader = new FileReader();
                reader.onloadend = () => resolve(reader.result.split(',')[1]);
                reader.readAsDataURL(blob);
            });
        }

        // --- 4. FUNCIÓN PRINCIPAL ---
        window.startAI = async (ocasion) => {
            if (!genAIModel) {
                alert("La IA aún no está lista. Verifica tu conexión e intenta de nuevo.");
                return;
            }

            document.getElementById('step-occasion').style.display = 'none';
            document.getElementById('step-loading').style.display = 'flex';

            const canvas = document.createElement('canvas');
            canvas.width = video.videoWidth; canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0);
            const imgBase64 = canvas.toDataURL('image/jpeg').split(',')[1];

            try {
                // Perfilado
                const perfilRes = await genAIModel.generateContent([
                    { inlineData: { data: imgBase64, mimeType: "image/jpeg" } },
                    { text: "¿Es HOMBRE o MUJER? Responde una sola palabra." }
                ]);
                const perfil = perfilRes.response.text().trim().toUpperCase();
                document.getElementById('loading-text').innerText = `Analizando catálogo de ${perfil}...`;

                // Carga de PDF
                const pdfUrl = GITHUB_PDFS[perfil] || GITHUB_PDFS.MUJER;
                const pdfBase64 = await fetchPdfBase64(pdfUrl);

                // Análisis Final
                const result = await genAIModel.generateContent([
                    "Eres AURAM, asistente de moda empático. Eleva el autoestima. Analiza foto y PDF.",
                    { inlineData: { data: imgBase64, mimeType: "image/jpeg" } },
                    { inlineData: { data: pdfBase64, mimeType: "application/pdf" } },
                    `Voy a ${ocasion}. Recomienda una prenda específica del PDF con precio en S/.`
                ]);

                // Mostrar Resultado
                document.getElementById('step-loading').style.display = 'none';
                document.getElementById('step-result').style.display = 'flex';
                document.getElementById('res-title').innerText = `AURA: ${perfil}`;
                
                // Formatear precios en azul
                const textoFinal = result.response.text().replace(/(S\/\.\s?\d+)/g, '<span style="color:#00d1ff; font-weight:bold;">$1</span>');
                document.getElementById('res-body').innerHTML = textoFinal;

            } catch (err) {
                console.error(err);
                alert("Error de procesamiento. Asegúrate de usar Live Server (http://127.0.0.1).");
                document.getElementById('step-loading').style.display = 'none';
            }
        };
    </script>
</body>
</html>
